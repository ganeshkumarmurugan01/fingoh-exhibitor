{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/upload",
      "destination": "/api/upload"
    },
    {
      "source": "/api/:slug*",
      "destination": "/api/proxy?slug=:slug*"
    },
    {
      "source": "/meeting",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}